t":true,"commentDisableAfterDaysDefault":0,"disqusShortname":"","commentsEnabled":false,"contactPhoneNumber":"(225) 677-2600 or (225) 366-7415","businessHours":{"monday":{"text":"9:00am - 5:00pm","ranges":[{"from":540,"to":1020}]},"tuesday":{"text":"9:00am - 5:00pm","ranges":[{"from":540,"to":1020}]},"wednesday":{"text":"9:00am - 5:00pm","ranges":[{"from":540,"to":1020}]},"thursday":{"text":"9:00am - 5:00pm","ranges":[{"from":540,"to":1020}]},"friday":{"text":"9:00am - 5:00pm","ranges":[{"from":540,"to":1020}]},"saturday":{"text":"Closed","ranges":[{}]},"sunday":{"text":"Closed","ranges":[{}]}},"contactEmail":"thefloralcottageflorist@gmail.com","storeSettings":{"returnPolicy":"<p class=\"\" style=\"white-space:pre-wrap;\">The floral arrangement can only be canceled at the time of pick up if the item is not satisfactory. Once the item(s) is picked up from our location, it cannot be returned. Please contact the Floral Cottage via text or call at 225-366-7415 or 225-677-2600 with questions. </p>","termsOfService":"<p class=\"\" style=\"white-space:pre-wrap;\">The Floral Cottage will provide the customer with a high quality product based on the monetary amount and description as listed. Products may vary as fresh flowers vary greatly depending on seasonal availability. We guarantee quality and freshness of your flowers. With proper care, fresh flowers should last approximately 5-7 days depending on flower type. If you have any questions or problems with your order, please contact us via text or call at 225-366-7415 or 225-677-2600 immediately before you leave with the item. </p><p class=\"\" style=\"white-space:pre-wrap;\">PICK UP LOCATION: The Floral Cottage Florist 38480 La-42, Prairieville, LA 70769</p>","privacyPolicy":"<p>Customers purchases will be processed through Swipe, a secure online payment site. The customer's personal information will not be viewed or shared by anyone outside of The Floral Cottage.</p>","expressCheckout":false,"continueShoppingLinkUrl":"/"