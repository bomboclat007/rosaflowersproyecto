arespace.com/universal/scripts-compressed/social-buttons-29c43f8081c385c1-min.en-US.js"},"squarespace-tourdates":{"css":"//assets.squarespace.com/universal/styles-compressed/tourdates-b4046463b72f34e2-min.en-US.css","js":"//assets.squarespace.com/universal/scripts-compressed/tourdates-56ede5cc8107aee7-min.en-US.js"},"squarespace-website-overlays-manager":{"css":"//assets.squarespace.com/universal/styles-compressed/website-overlays-manager-07ea5a4e004e6710-min.en-US.css","js":"//assets.squarespace.com/universal/scripts-compressed/website-overlays-manager-44ce067a6a01c6fb-min.en-US.js"}},"pageType":50,"website":{"id":"56aa9020d51cd471ca1987f8","identifier":"thefloralcottageflorist","websiteType":4,"contentModifiedOn":1761338741071,"cloneable":false,"hasBeenCloneable":false,"siteStatus":{},"language":"en-US","translationLocale":"en-US","formattingLocale":"en-US","timeZone":"America/Chicago","machineTimeZoneOffset":-18000000,"timeZoneOffset":-18000000,"timeZoneAbbr":"CDT","siteTitle":"The Floral Cottage","fullSiteTitle":"Signature Spray \u2014 The Floral Cottage","siteTagLine":"","location":{"mapZoom":12.0,"mapLat":30.3210756,"mapLng":-90.96082489999999,"markerLat":30.2041005,"markerLng":-90.8349581,"addressTitle":"The Floral Cottage Florist","addressLine1":"38480 Louisiana 42","addressLine2":"Prairieville, LA, 70769","addressCountry":"United States"},"logoImageId":"6778112498cd4824050e9b3e","socialLogoImageId":"667f13aa27e4212f6cb76b11","shareButtonOptions":{"6":true,"7":true,"1":true,"4":true,"8":true,"2":true,"3":true},"logoImageUrl":"//images.squarespace-cdn.com/content/v1/56aa9020d51cd471ca1987f8/569712f9-bcaa-42d5-a41c-ed4562760cc1/round%2Blogo.png","socialLogoImageUrl":"//images.squarespace-cdn.com/content/v1/56aa9020d51cd471ca1987f8/e64449a2-adc1-48a2-bcda-b37448d8cf99/logo.PNG","authenticUrl":"https://www.thefloralcottageflorist.com","internalUrl":"https://thefloralcottageflorist.squarespace.com","baseUrl":"https://www.thefloralcottageflorist.com","primaryDomai