{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "**/*", "use": "@vercel/static" }
  ],
  "routes": [
  { "src": "^/$", "dest": "/index.html" },
    { "src": "^/assets/css/disable-login.css", "headers": { "cache-control": "public, max-age=0, must-revalidate" }, "dest": "/assets/css/disable-login.css" },
    { "handle": "filesystem" },
    { "src": "^/api/(.*)$", "dest": "/api/$1.js" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}